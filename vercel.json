{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/public/$1"
    }
  ],
  "routes": [
    {
      "src": "/contact-us.html",
      "status": 301,
      "headers": { "Location": "/contact-us" }
    },
    {
      "src": "/terms-and-conditions.html",
      "status": 301,
      "headers": { "Location": "/terms-and-conditions" }
    },
    {
      "src": "/privacy-policy.html",
      "status": 301,
      "headers": { "Location": "/privacy-policy" }
    },
    {
      "src": "/cancellation-and-refund.html",
      "status": 301,
      "headers": { "Location": "/cancellation-and-refund" }
    },
    {
      "src": "/shipping-and-exchange.html",
      "status": 301,
      "headers": { "Location": "/shipping-and-exchange" }
    },
    {
      "src": "/templates.html",
      "status": 301,
      "headers": { "Location": "/templates" }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "status": 404,
      "dest": "/public/index.html"
    }
  ]
}
